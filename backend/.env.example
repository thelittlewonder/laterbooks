GOODREADS_EMAIL=your@email.com
GOODREADS_PASSWORD=your_password
GOODREADS_LOGIN_METHOD=goodreads

# Preferred on Render — paste JSON from: python scripts/export_goodreads_session.py
# GOODREADS_STORAGE_STATE={"cookies":[...],"origins":[...]}

PLAYWRIGHT_HEADLESS=true
MAX_PHOTOS=10

# Comma-separated frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
