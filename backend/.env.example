# Free OCR — use ONE of these:

# Option A: API key (Credentials → Create credentials → API key)
# GOOGLE_VISION_API_KEY=AIzaSy...

# Option B: Service account JSON (recommended — use this OR the API key, not both)
# GOOGLE_VISION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# If using Option B, delete GOOGLE_VISION_API_KEY from Render to avoid conflicts.

GOODREADS_EMAIL=your@email.com
GOODREADS_PASSWORD=your_password
GOODREADS_LOGIN_METHOD=goodreads

PLAYWRIGHT_HEADLESS=true
MAX_PHOTOS=10
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
